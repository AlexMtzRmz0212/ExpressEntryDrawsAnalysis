# Copy this file to .env for local development.
# NEVER commit .env — it is listed in .gitignore.
# On Vercel, add these in: Project → Settings → Environment Variables

# Supabase — find at: project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Arbitrary secret that protects POST /api/refresh from abuse
REFRESH_SECRET=change-me-to-something-long-and-random
