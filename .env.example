# Copy this file to .env for local development.
# NEVER commit .env — it is listed in .gitignore.
# On Vercel, add these in: Project → Settings → Environment Variables

# Supabase — find at: project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Arbitrary secret that protects POST /api/refresh from abuse
REFRESH_SECRET=change-me-to-something-long-and-random

# Secret used by Vercel cron jobs — Vercel injects this automatically as a
# Bearer token when calling GET /api/cron on its schedule.
# Set this to any long random string; add it in Vercel → Settings → Environment Variables.
CRON_SECRET=change-me-to-something-long-and-random

# --- Email notifications -----------------------------------------------------
# Leave RESEND_API_KEY unset to disable all outbound mail. The subscribe form
# then returns an error, and the notifier no-ops instead of failing.

# Resend API key — resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From header. The domain must be verified in Resend (DKIM + SPF DNS records)
# or mail will be rejected or land in spam.
MAIL_FROM=Express Entry Draws <notifications@ee.bittobyte.qzz.io>

# Where "someone subscribed / unsubscribed" alerts are sent. Unset = no alerts.
ADMIN_EMAIL=you@example.com

# Public base URL, used to build confirm and unsubscribe links in emails.
SITE_URL=https://ee.bittobyte.qzz.io

# Postal address printed in the footer of every subscriber email.
# REQUIRED before going live: Canada's anti-spam legislation (CASL) requires a
# physical or postal mailing address in commercial email. A PO box is fine.
MAIL_SENDER_ADDRESS=Your Name, 123 Example St, Toronto, ON M1A 1A1, Canada
